rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net (Default Deny)
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    function isMasterAdmin() {
      return isSignedIn() && 
             request.auth.token.email != null && 
             (request.auth.token.email == "mlbbguildbangladesh@gmail.com" || request.auth.token.email.toLower() == "mlbbguildbangladesh@gmail.com");
    }

    function isVerified() { 
      return isSignedIn() && (
        isMasterAdmin() ||
        request.auth.token.email_verified == true ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isVerified', false) == true)
      ); 
    }

    function isAdmin() { 
      return isMasterAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin'
      ); 
    }

    function isModerator(perm) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/settings/global) &&
             get(/databases/$(database)/documents/settings/global).data.get('moderatorPermissions', {}).get(request.auth.uid, []).hasAny([perm]);
    }

    function isStaff(perm) {
      return isMasterAdmin() || isAdmin() || isModerator(perm);
    }

    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isTeamOwner(teamId) {
       return isSignedIn() && (
         teamId == request.auth.uid || 
         (exists(/databases/$(database)/documents/teams/$(teamId)) && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerId == request.auth.uid) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('teamId', '') == teamId)
       );
    }

    function canListTransactions() {
      return isStaff('transactions') || isStaff('matches') || 
             (isSignedIn() && (
               resource.data.get('ownerId', '') == request.auth.uid || 
               resource.data.get('teamId', '') == request.auth.uid ||
               request.auth.uid in resource.data.get('allowedViewerUids', [])
             ));
    }

    function canListRegistrations() {
       return resource.data.get('status', 'none') == 'approved' || 
              isStaff('registrations') || 
              isOwner(resource.data.get('ownerId', '')) || 
              isOwner(resource.data.get('userId', ''));
    }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.email is string && data.email.size() <= 128 &&
             data.get('role', 'team') in ['admin', 'team'] &&
             data.get('points', 0) is number &&
             data.get('diamonds', 0) is number &&
             data.get('gameId', '') is string && data.get('gameId', '').size() <= 64 &&
             data.get('serverId', '') is string && data.get('serverId', '').size() <= 64 &&
             data.get('phoneNumber', '') is string && data.get('phoneNumber', '').size() <= 32 &&
             data.get('teamName', '') is string && data.get('teamName', '').size() <= 64;
    }

    function isValidTeam(data) {
      return data.teamName is string && data.teamName.size() <= 64 &&
             data.leaderName is string && data.leaderName.size() <= 64 &&
             data.players is list && data.players.size() <= 7 &&
             data.ownerId is string && data.ownerId.size() <= 128;
    }

    function isValidRegistration(data) {
      return data.teamName is string && data.teamName.size() <= 64 &&
             data.leaderName is string && data.leaderName.size() <= 64 &&
             data.leaderEmail is string && data.leaderEmail.size() <= 128 &&
             (data.get('userId', '') == request.auth.uid || data.get('ownerId', '') == request.auth.uid) &&
             data.status == 'pending' &&
             data.players is list && data.players.size() <= 7;
    }

    // --- Rules ---

    match /users/{userId} {
      allow read: if isOwner(userId) || isStaff('users') || isStaff('matches');
      
      allow create: if (
        isValidId(userId) &&
        isOwner(userId) &&
        isValidUser(incoming())
      );

      allow update: if (
        isSignedIn() && (
          isStaff('users') || isStaff('logo-update') || isStaff('matches') || (
            isOwner(userId) && (
              // Allow point deduction for penalties (e.g. declining challenges)
              (
                incoming().get('points', 0) < existing().get('points', 0) &&
                incoming().diff(existing()).affectedKeys().hasOnly(['points'])
              ) ||
              // Existing profile edit logic
              (
                (exists(/databases/$(database)/documents/settings/global) == false || get(/databases/$(database)/documents/settings/global).data.get('profileEditsEnabled', true) == true) &&
                !incoming().diff(existing()).affectedKeys().hasAny(['role', 'points', 'diamonds', 'isVerified', 'isAdmin'])
              )
            )
          )
        )
      );
      
      allow delete: if isAdmin();
    }

    match /teams/{teamId} {
      allow read, list: if true;
      
      allow create: if isValidId(teamId) && (isStaff('teams') || isStaff('registrations') || (isSignedIn() && isValidTeam(incoming()) && incoming().ownerId == request.auth.uid)); 
      
      allow update: if (
        isSignedIn() && (
          isStaff('teams') || isStaff('logo-update') || isStaff('matches') || (
            isTeamOwner(teamId) &&
            // Allow Rank Upgrade or Point Deduction
            (
              (
                incoming().get('points', 0) < existing().get('points', 0) && 
                incoming().diff(existing()).affectedKeys().hasOnly(['points'])
              ) ||
              (
                incoming().get('points', 0) < existing().get('points', 0) &&
                incoming().diff(existing()).affectedKeys().hasOnly(['points', 'rank'])
              ) ||
              (
                // Existing profile edit logic
                (exists(/databases/$(database)/documents/settings/global) == false || get(/databases/$(database)/documents/settings/global).data.get('profileEditsEnabled', true) == true) &&
                incoming().get('ownerId', existing().get('ownerId', '')) == existing().get('ownerId', '') &&
                !incoming().diff(existing()).affectedKeys().hasAny(['role', 'points', 'diamonds', 'isVerified', 'isAdmin'])
              )
            )
          ) || (
            // Support for batch increments of matchesThisSeason or player recruitment
            incoming().diff(existing()).affectedKeys().hasOnly(['matchesThisSeason']) ||
            incoming().diff(existing()).affectedKeys().hasOnly(['players', 'recruitmentSlots'])
          )
        )
      );
      
      allow delete: if isAdmin();
    }

    match /registrations/{regId} {
      allow create: if isValidId(regId) && isSignedIn() && isValidRegistration(incoming());
      allow get: if isStaff('registrations') || (isSignedIn() && (resource != null && (existing().get('ownerId', '') == request.auth.uid || existing().get('userId', '') == request.auth.uid))) || (resource != null && resource.data.get('status', '') == 'approved');
      allow list: if resource.data.get('status', '') == 'approved' || isSignedIn();
      allow write: if isStaff('registrations');
    }

    match /matches/{matchId} {
      allow read, list: if true;
      allow write: if isStaff('matches');
    }

    match /transactions/{transId} {
      allow read: if isStaff('transactions') || isStaff('matches') || (isSignedIn() && resource != null && (existing().get('teamId', '') == request.auth.uid || existing().get('ownerId', '') == request.auth.uid || request.auth.uid in existing().get('allowedViewerUids', [])));
      allow list: if canListTransactions();
      allow create: if isSignedIn() && (
        isStaff('transactions') || isStaff('matches') || 
        (incoming().get('ownerId', '') == request.auth.uid || isTeamOwner(incoming().get('teamId', '')))
      );
      allow write: if isStaff('transactions') || isStaff('matches');
    }

    match /challenges/{challengeId} {
      allow read, list: if true;
      allow create: if isSignedIn() && isTeamOwner(incoming().get('fromTeamId', ''));
      allow update, delete: if isStaff('challenges') || (isSignedIn() && (
        isTeamOwner(challengeId) || 
        isTeamOwner(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('teamId', '')) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('teamId', '') in existing().get('targetTeamIds', [])
      ));
    }

    match /schedules/{scheduleId} {
      allow read, list: if true;
      allow update, delete: if isStaff('schedules');
      allow create: if isSignedIn() && (
        isStaff('schedules') || 
        incoming().get('matchType', '') == 'challenge'
      );
    }

    match /seasons/{seasonId} {
      allow read, list: if true;
      allow write: if isStaff('seasons');
    }

    match /passwordRequests/{reqId} {
      allow create: if true;
      allow read, write: if isStaff('pass-reqs');
    }

    match /soloPlayers/{playerId} {
      allow read, list: if true;
      allow create: if isSignedIn() && (incoming().get('userId', '') == request.auth.uid || playerId == request.auth.uid);
      allow update: if isAdmin() || (isSignedIn() && (
        (existing().get('userId', '') == request.auth.uid || playerId == request.auth.uid) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['status']))
      ));
      allow delete: if isAdmin() || (isSignedIn() && (existing().get('userId', '') == request.auth.uid || playerId == request.auth.uid));
    }

    match /recruitmentRequests/{reqId} {
      allow read, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    match /notifications/{notificationId} {
      allow read, update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /live_links/{linkId} {
      allow read, list: if true;
      allow write, delete: if isStaff('live-links');
    }

    match /settings/{settingId} {
      allow read, list: if true;
      allow write: if isStaff('settings');
    }
  }
}
