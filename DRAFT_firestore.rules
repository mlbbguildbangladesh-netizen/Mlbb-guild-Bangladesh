rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isSignedIn() && 
             request.auth.token.email.lower() == "mlbbguildbangladesh@gmail.com"; 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'points', 'diamonds', 'createdAt']) &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['admin', 'team'] &&
             data.points is number &&
             data.diamonds is number &&
             data.createdAt is timestamp;
    }

    function isValidTeam(data) {
      return data.keys().hasAll(['teamName', 'leaderName', 'points', 'diamonds', 'ownerId', 'createdAt']) &&
             data.teamName is string && data.teamName.size() <= 64 &&
             data.leaderName is string && data.leaderName.size() <= 64 &&
             data.points is number &&
             data.diamonds is number &&
             data.ownerId is string &&
             data.createdAt is timestamp;
    }

    function isValidRegistration(data) {
      return data.keys().hasAll(['teamName', 'leaderName', 'leaderEmail', 'userId', 'status', 'timestamp']) &&
             data.teamName is string && data.teamName.size() <= 64 &&
             data.leaderName is string && data.leaderName.size() <= 64 &&
             data.leaderEmail is string && data.leaderEmail.size() <= 100 &&
             data.userId == request.auth.uid &&
             data.status == 'pending' &&
             data.timestamp == request.time;
    }

    // --- Rules ---

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if (
        isOwner(userId) && 
        isValidUser(incoming()) && 
        incoming().role == 'team' &&
        incoming().points == 0 &&
        incoming().diamonds == 0 &&
        incoming().createdAt == request.time
      );

      allow update: if (
        isValidUser(incoming()) && (
          isAdmin() || (
            isOwner(userId) && 
            incoming().role == existing().role &&
            incoming().points == existing().points &&
            incoming().diamonds == existing().diamonds &&
            incoming().createdAt == existing().createdAt &&
            incoming().diff(existing()).affectedKeys().hasOnly(['teamName', 'leaderName', 'displayName', 'email', 'teamId'])
          )
        )
      );
      
      allow delete: if isAdmin();
    }

    match /teams/{teamId} {
      allow read: if true;
      allow list: if true; // Public listings are okay as they are non-sensitive and filterable by status usually
      
      allow create: if isAdmin(); // Teams are created by admin after registration approval
      
      allow update: if (
        isValidTeam(incoming()) && (
          isAdmin() || (
            isOwner(existing().ownerId) &&
            incoming().ownerId == existing().ownerId &&
            incoming().points == existing().points &&
            incoming().diamonds == existing().diamonds &&
            incoming().createdAt == existing().createdAt &&
            incoming().diff(existing()).affectedKeys().hasOnly(['teamName', 'leaderName', 'logoUrl', 'leaderCardUrl', 'players'])
          )
        )
      );
      
      allow delete: if isAdmin();
    }

    match /registrations/{regId} {
      allow create: if isSignedIn() && isValidRegistration(incoming()) && isValidId(regId);
      allow read, write: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /transactions/{transId} {
      allow read: if isAdmin() || (isSignedIn() && existing().teamId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /challenges/{challengeId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().fromTeamId is string; 
      allow update, delete: if isAdmin();
    }

    match /schedules/{scheduleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
